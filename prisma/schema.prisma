generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Papéis de usuário que podem existir no sistema
enum Role {
  ADMIN
  REFEREE
}

// Modelo para usuários (tanto Admin quanto Árbitros)
model User {
  id                 Int      @id @default(autoincrement())
  username           String   @unique
  password           String
  role               Role     @default(REFEREE)
  
  createdTournaments Tournament[] @relation("OrganizerToTournament")
  submittedScores    Score[]      @relation("RefereeToScore")
  
  // Relação N-M: Um árbitro pode estar em vários torneios
  tournaments        RefereesInTournament[]
}

model Tournament {
  id           Int      @id @default(autoincrement())
  name         String
  date         DateTime
  location  String?
  description    String?
  
  organizer    User     @relation("OrganizerToTournament", fields: [organizerId], references: [id])
  organizerId  Int
  
  categories   CategoryInTournament[]
  athletes     Athlete[]
  
  // Relação N-M: Um torneio tem vários árbitros
  referees     RefereesInTournament[]

  results      AthleteResult[]
}

// Tabela de Junção para a relação N-M (Árbitros em Torneios)
model RefereesInTournament {
  referee      User       @relation(fields: [refereeId], references: [id])
  refereeId    Int
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  tournamentId Int

  @@id([refereeId, tournamentId]) // Chave primária composta
}

// Modelo MESTRE para TODAS as categorias possíveis
model Category {
  id    Int    @id @default(autoincrement())
  name  String @unique // "Faixa Preta - Master 1 - Masculino"
  
  // Relacionamento N-M com Torneio
  tournaments CategoryInTournament[]
  // Uma categoria pode ter vários atletas (de diferentes torneios)
  athletes    Athlete[]
}

// Tabela de Junção (Join Table) para a relação N-M
// Diz quais categorias estão em qual torneio
model CategoryInTournament {
  category     Category   @relation(fields: [categoryId], references: [id])
  categoryId   Int
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  tournamentId Int

  @@id([categoryId, tournamentId]) // Chave primária composta
}

model Athlete {
  id   Int    @id @default(autoincrement())
  name String

  // O Atleta agora pertence diretamente a um Torneio e a uma Categoria Mestre
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  tournamentId Int
  category     Category   @relation(fields: [categoryId], references: [id])
  categoryId   Int

  scores Score[]
  results    AthleteResult[]
}

model AthleteResult {
  id             Int      @id @default(autoincrement())
  finalScore     Float    // A nota final calculada
  precisionAvg   Float
  presentationAvg Float
  rawScoreSum     Float   @default(0)
  presentationNumber Int      @default(1)

  athlete      Athlete    @relation(fields: [athleteId], references: [id])
  athleteId    Int
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  tournamentId Int

  // Garante que um atleta só pode ter um resultado por torneio
  @@unique([athleteId, tournamentId, presentationNumber])
}

// O modelo Score permanece praticamente o mesmo
model Score {
  id           Int     @id @default(autoincrement())
  precision    Float
  presentation Float
  
  athlete      Athlete @relation(fields: [athleteId], references: [id])
  athleteId    Int
  
  referee      User    @relation("RefereeToScore", fields: [refereeId], references: [id])
  refereeId    Int
}
